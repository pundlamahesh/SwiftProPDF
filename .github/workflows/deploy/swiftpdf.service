[Unit]
Description=SwiftPDF Flask App
After=network.target

[Service]
User=ubuntu
Group=ubuntu

WorkingDirectory=/home/ubuntu/SwiftPDF
EnvironmentFile=/home/ubuntu/SwiftPDF/.env

ExecStart=/home/ubuntu/venv/bin/gunicorn \
  -w 4 \
  -b 127.0.0.1:8000 \
  --timeout 300 \
  "SwiftPDF.web:create_app()"

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target