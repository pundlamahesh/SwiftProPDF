# SwiftProPDF environment
# Copy to .env and replace values for your deployment.

# Required in production. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SWIFTPROPDF_SECRET_KEY=change-this-in-production

# Set to 1 only when serving over HTTPS.
SWIFTPROPDF_COOKIE_SECURE=0

# PostgreSQL database. Docker Compose overrides this to use the postgres service.
DATABASE_URL=postgresql://swiftpropdf_dbuser:Password%40123@localhost:5432/swiftpropdf

# Background processing. Docker Compose enables this automatically.
SWIFTPROPDF_ASYNC_TOOLS=0
SWIFTPROPDF_ASYNC_WORKER_CONCURRENCY=2
SWIFTPROPDF_JOBS_DIR=src/SwiftProPDF/instance/jobs
REDIS_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
SWIFTPROPDF_JOB_RESULT_EXPIRES=86400

# Antivirus scanning. Docker Compose enables this automatically.
CLAMAV_ENABLED=0
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30
