# SwiftPDF Environment Configuration Template
# Copy this file to .env and update values for your environment

# Flask Environment
# Options: development, production
FLASK_ENV=production

# Secret Key for Flask Sessions
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SWIFTPDF_SECRET_KEY=your-super-secret-key-change-this-in-production

# File Upload Configuration
# Maximum file size in bytes (default: 100MB = 104857600 bytes)
MAX_CONTENT_LENGTH=104857600

# Database Configuration
# Path to SQLite database
DATABASE_PATH=./instance/swiftpdf.sqlite3

# Temporary Files Configuration
# Directory for temporary processing files
TEMP_DIR=/tmp/swiftpdf

# PDF Processing Configuration
# Default DPI for PDF to image conversion (72-300)
PDF_DPI_DEFAULT=150

# Maximum DPI for PDF to image conversion
PDF_DPI_MAX=300

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
LOG_FILE=./logs/swiftpdf.log

# Server Configuration
# Host to bind to (127.0.0.1 for localhost only, 0.0.0.0 for all interfaces)
FLASK_HOST=127.0.0.1

# Port to run on
FLASK_PORT=5000

# Request Timeout (seconds)
# Timeout for long-running PDF processing operations
REQUEST_TIMEOUT=300

# Processing Configuration
# Enable background job queue (if supported)
ENABLE_JOB_QUEUE=false

# Maximum concurrent processing jobs
MAX_CONCURRENT_JOBS=4

# LibreOffice Configuration
# Path to libreoffice executable (auto-detected if not specified)
# LIBREOFFICE_PATH=/usr/bin/libreoffice

# OCR Configuration (for future OCR support)
# ENABLE_OCR=false
# OCR_LANGUAGE=eng

# Rate Limiting (if implemented)
# Requests per minute per user
# RATE_LIMIT=100

# Security Configuration
# Session timeout in minutes
SESSION_TIMEOUT=1440

# Secure cookies (HTTPS only)
SECURE_COOKIES=true

# CORS Configuration
# Allowed origins for CORS (comma-separated)
# CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com

# Email Configuration (for notifications/recovery)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@example.com
# SMTP_PASSWORD=your-app-password
# SENDER_EMAIL=noreply@example.com
# SMTP_USE_TLS=1
# REGISTRATION_OTP_EXPIRY_MINUTES=10

# Storage Configuration
# Maximum disk usage for temporary files (GB)
MAX_TEMP_STORAGE=10

# Auto-cleanup temporary files older than (hours)
TEMP_FILE_CLEANUP_AGE=24

# Database Configuration
# Connection timeout (seconds)
DB_TIMEOUT=5

# Enable database WAL mode (Write-Ahead Logging) for better concurrency
DB_WAL_MODE=true

# API Configuration
# Enable API documentation
ENABLE_API_DOCS=false

# API authentication token (if implemented)
# API_TOKEN=your-secret-api-token

# Debugging (Development Only)
# DO NOT ENABLE IN PRODUCTION
DEBUG=false
DEVELOPMENT_MODE=false

# Performance Tuning
# Number of Flask threads
FLASK_THREADS=4

# Cache configuration
ENABLE_CACHING=true

# Monitoring/Telemetry
# Enable application monitoring
ENABLE_MONITORING=false

# Sentry DSN for error tracking (if using Sentry)
# SENTRY_DSN=https://your-sentry-url

# Notes for Configuration
# - For production, ensure FLASK_ENV=production
# - Change SWIFTPDF_SECRET_KEY to a strong random value
# - Set FLASK_HOST=0.0.0.0 if running behind a reverse proxy
# - Ensure TEMP_DIR has sufficient disk space and write permissions
# - Set SECURE_COOKIES=false only for local/development environments
# - Regularly rotate SESSION_TIMEOUT values
# - Monitor LOG_LEVEL for performance (use WARNING in production)
# - Ensure LibreOffice is installed for Office document conversion
